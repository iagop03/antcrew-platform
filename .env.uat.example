# antcrew-platform — UAT (User Acceptance Testing)
# Copy to .env.uat:  cp .env.uat.example .env.uat
# Used by: docker compose -f docker-compose.yml -f docker-compose.uat.yml up
#
# UAT is as close to prod as possible without live money.
# Use TEST-mode Stripe/LS keys. Reset data periodically (see below).

APP_ENV=uat

# ── Auth ─────────────────────────────────────────────────────────────────────
PLATFORM_API_KEY=                     # required — different value from int/prod
ANTCREW_REQUIRE_AUTH=true

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://antcrew:CHANGE_ME@postgres/antcrew_uat
POSTGRES_USER=antcrew
POSTGRES_PASSWORD=CHANGE_ME

# Data reset policy: UAT database is reset before each acceptance cycle.
# Run reset by dropping and recreating antcrew_uat, then restarting the platform
# so init_db() recreates all tables. Seed scripts live in tests/fixtures/ if any.

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Sandbox ───────────────────────────────────────────────────────────────────
ANTCREW_SANDBOX=required

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://uat.antcrew.dev

# ── Stripe — TEST keys only in UAT ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ── Lemon Squeezy — test mode ─────────────────────────────────────────────────
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# ── Encryption ────────────────────────────────────────────────────────────────
BYOK_ENCRYPTION_KEY=
SLACK_TOKEN_ENCRYPTION_KEY=

# ── Slack (optional) ──────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Trial ─────────────────────────────────────────────────────────────────────
TRIAL_CREDIT_USD=5.0
TRIAL_MAX_PER_IP=5
