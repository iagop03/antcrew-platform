# antcrew-platform — complete variable reference
#
# This file documents every supported variable and which environments they apply to.
# For a ready-to-use starting point copy the env-specific example instead:
#
#   dev:  cp .env.dev.example .env
#   int:  cp .env.int.example .env.int
#   uat:  cp .env.uat.example .env.uat
#   prod: cp .env.prod.example .env.prod

# ── Environment ───────────────────────────────────────────────────────────────
# Required. One of: dev | int | uat | prod
# Controls which startup guards are enforced and which credentials are expected.
APP_ENV=dev

# ── Authentication ────────────────────────────────────────────────────────────
# Single shared API key (all callers use the same key).
# Leave unset in dev for open mode. Required in int/uat/prod (ANTCREW_REQUIRE_AUTH=true).
# PLATFORM_API_KEY=

# Block startup when no credentials are configured.
# ANTCREW_REQUIRE_AUTH=true

# ── Database ──────────────────────────────────────────────────────────────────
# Defaults to SQLite (dev only). PostgreSQL required in int/uat/prod.
# DATABASE_URL=sqlite+aiosqlite:///./platform.db
# DATABASE_URL=postgresql+asyncpg://user:pass@host/antcrew_dev
# POSTGRES_USER=antcrew
# POSTGRES_PASSWORD=

# ── LLM ──────────────────────────────────────────────────────────────────────
# Platform-managed Anthropic key (used when workspace is in managed mode).
# Use separate keys per environment to isolate spend.
ANTHROPIC_API_KEY=sk-ant-...

# ── Sandbox ───────────────────────────────────────────────────────────────────
# Required in int/uat/prod. Optional in dev (auto = Docker if available).
# ANTCREW_SANDBOX=required

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Unset = localhost only.
# Wildcard (*) blocked on public hosts.
# CORS_ORIGINS=https://antcrew.dev

# ── Stripe ────────────────────────────────────────────────────────────────────
# dev/int/uat: sk_test_* keys only.
# prod: sk_live_* only — sk_test_* blocks startup (guard enforced).
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# ── Lemon Squeezy (Merchant of Record) ───────────────────────────────────────
# LEMON_SQUEEZY_API_KEY=
# LEMON_SQUEEZY_STORE_ID=
# LEMON_SQUEEZY_WEBHOOK_SECRET=

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required on public hosts when BYOK keys or Slack tokens exist in the DB.
# BYOK_ENCRYPTION_KEY=
# SLACK_TOKEN_ENCRYPTION_KEY=

# ── Slack ─────────────────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json    # json (structured, for log shippers) | text (human-readable, for dev)

# ── Free trial ────────────────────────────────────────────────────────────────
TRIAL_CREDIT_USD=5.0      # USD credit given to each free-trial workspace
TRIAL_MAX_PER_IP=5        # max registrations per IP per 24 h (0 = unlimited)

# ── Data retention ────────────────────────────────────────────────────────────
DATA_RETENTION_DAYS=30    # terminal webhook deliveries and events older than this are pruned
