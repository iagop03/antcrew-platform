# Copy to .env and fill in values

# Anthropic API key (required for running teams)
ANTHROPIC_API_KEY=sk-ant-...

# Platform API key — if set, all endpoints require X-Api-Key header
# Leave unset for local/dev (open mode)
# PLATFORM_API_KEY=your-secret-key

# Database URL — defaults to SQLite
# For PostgreSQL: postgresql+asyncpg://user:pass@host/dbname
# DATABASE_URL=sqlite+aiosqlite:///./platform.db
