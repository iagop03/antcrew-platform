# antcrew-platform — development
# Copy to .env for local development:  cp .env.dev.example .env
#
# Guards are relaxed on dev (localhost, SQLite OK, sandbox optional).
# NEVER copy these values into int/uat/prod.

APP_ENV=dev

# Platform-managed LLM key
ANTHROPIC_API_KEY=sk-ant-...

# Auth — leave unset for open mode (dev only, no credentials required)
# PLATFORM_API_KEY=dev-secret

# Database — SQLite default; PostgreSQL not required in dev
# DATABASE_URL=sqlite+aiosqlite:///./platform.db

# Sandbox — optional on dev, required on all other envs
# ANTCREW_SANDBOX=auto

# Trial credit (USD) given to new free-trial workspaces
TRIAL_CREDIT_USD=5.0

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# CORS — unset = localhost only
# CORS_ORIGINS=http://localhost:3000
