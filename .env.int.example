# antcrew-platform — integration
# Copy to .env.int:  cp .env.int.example .env.int
# Used by: docker compose -f docker-compose.yml -f docker-compose.int.yml up
#
# All guards are active. Use TEST-mode keys only — never live/prod keys.

APP_ENV=int

# ── Auth ─────────────────────────────────────────────────────────────────────
PLATFORM_API_KEY=                     # required — set a strong random value
ANTCREW_REQUIRE_AUTH=true

# ── Database — PostgreSQL required in non-dev ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://antcrew:CHANGE_ME@postgres/antcrew_int
POSTGRES_USER=antcrew
POSTGRES_PASSWORD=CHANGE_ME           # also used by the postgres service in compose

# ── LLM ──────────────────────────────────────────────────────────────────────
# Use a dedicated int API key to isolate spend from prod
ANTHROPIC_API_KEY=sk-ant-...

# ── Sandbox ───────────────────────────────────────────────────────────────────
ANTCREW_SANDBOX=required

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://int.antcrew.dev

# ── Stripe — TEST keys only in int ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ── Lemon Squeezy — test mode ─────────────────────────────────────────────────
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BYOK_ENCRYPTION_KEY=
SLACK_TOKEN_ENCRYPTION_KEY=

# ── Slack (optional) ──────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Trial ─────────────────────────────────────────────────────────────────────
TRIAL_CREDIT_USD=5.0
TRIAL_MAX_PER_IP=5
