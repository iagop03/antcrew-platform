# antcrew-platform — production
# Copy to .env.prod:  cp .env.prod.example .env.prod
# Used by: docker compose -f docker-compose.yml -f docker-compose.prod.yml up
#
# LIVE KEYS ONLY. A sk_test_* Stripe key in prod blocks startup (guard enforced).
# NEVER commit .env.prod. Store secrets in your secrets manager and inject at deploy.

APP_ENV=prod

# ── Auth ─────────────────────────────────────────────────────────────────────
PLATFORM_API_KEY=                     # required — strong random value, rotated periodically
ANTCREW_REQUIRE_AUTH=true

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://antcrew:CHANGE_ME@postgres/antcrew_prod
POSTGRES_USER=antcrew
POSTGRES_PASSWORD=CHANGE_ME           # rotate via pg_changeuserpw, update and restart

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # dedicated prod key — separate quota from int/uat

# ── Sandbox ───────────────────────────────────────────────────────────────────
ANTCREW_SANDBOX=required              # mandatory — never remove in prod

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://antcrew.dev,https://www.antcrew.dev

# ── Stripe — LIVE keys only ───────────────────────────────────────────────────
# sk_test_* here will block startup (see _check_stripe_key_mode in main.py)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ── Lemon Squeezy — live mode ─────────────────────────────────────────────────
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store in your secrets manager (Vault, AWS SSM, GCP Secret Manager, Doppler…)
BYOK_ENCRYPTION_KEY=
SLACK_TOKEN_ENCRYPTION_KEY=

# ── Slack (optional) ──────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=WARNING                     # reduce noise; INFO for new deploys, then tune down
LOG_FORMAT=json

# ── Trial ─────────────────────────────────────────────────────────────────────
TRIAL_CREDIT_USD=5.0
TRIAL_MAX_PER_IP=5

# ── Retention ─────────────────────────────────────────────────────────────────
DATA_RETENTION_DAYS=30
